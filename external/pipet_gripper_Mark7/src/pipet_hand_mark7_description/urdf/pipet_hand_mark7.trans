<?xml version="1.0" ?>
<robot name="pipet_hand_mark7_20251226" xmlns:xacro="http://www.ros.org/wiki/xacro" >

  <transmission name="base_pinky_tran">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="base_pinky">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
